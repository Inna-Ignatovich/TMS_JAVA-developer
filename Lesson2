 * @Date 06.03.2026
 */
public class Main {
    private static Scanner sc = new Scanner(System.in);

    public static void main(String[] args) {
        //Задача 1:
        /**
         * Напишите программу, которая будет принимать на вход число из консоли и на выход
         * Напишите программу, которая будет принимать на вход число из консоли и на выход
         * будет выводить сообщение четное число или нет.
         */
        Task1();

        //Задача 2:
        /*Для введенного числа t (температура на улице) вывести: Если t>–5, то вывести «Warm».
        Если –5>= t > –20, то вывести «Normal». Если –20>= t, то вывести «Cold».
        */
        Task2();

        //Задача 3:
        /*Составьте программу, выводящую на экран квадраты чисел от 10 до 20 включительно.*/
        Task3();

        //  Задача 4:
        /* Необходимо, чтоб программа выводила на экран вот такую последовательность:
        7 14 21 28 35 42 49 56 63 70 77 84 91 98. В решении используйте цикл while.
         */
        Task4();

        // Задача 5:
      /*  Напишите программу, где пользователь вводит любое целое положительное число. А
        программа суммирует все числа от 1 до введенного пользователем числа. Для ввода
        числа воспользуйтесь классом Scanner. Сделать проверку, чтобы пользователь не мог
        ввести некорректные данные.
       */
        Task5();
    }

    public static void Task1() {
        System.out.println("Задача 1.");;
        System.out.println("Введите число:");
        int a = sc.nextInt();
        if (a % 2 == 0) {
            System.out.println("Ответ: число " + a + " - чётное.");
        } else {
            System.out.println("Ответ: число " + a + " - нечётное.");
        }
    }

    public static void Task2() {
        System.out.println("Задача 2.");
        System.out.println("Введите температуру на улице:");
        int temp = sc.nextInt();
        if (temp > -5) {
            System.out.println("Ответ:. Warm");
        } else if (temp <= -20) {
            System.out.println("Ответ: Cold");
        } else {
            System.out.println("Ответ:1 Normal");
        }
    }

    public static void Task3() {
        System.out.println("Задача 3. Ответ:");
        for (int i = 10; i <= 20; i++) {
            System.out.println(i * i);
        }

    }
    public static void Task4() {
        System.out.println("Задача 4.");;
        int n = 7;
        System.out.print("Ответ:");
        while (n <= 98) {
            System.out.print(n + " ");
            n = n + 7;
        }
        System.out.println(" ");
    }
    public static void Task5() {
        while (true) {
            System.out.println("Задача 5.");;
            System.out.println("Введите любое целое положительное число: ");

            if (sc.hasNextInt() ) {
                int resultNum = 0;
                int inputNum = sc.nextInt();
                if (inputNum < 0) {
                    System.out.println("Введите число больше 0!");
                    sc.next();
                }
                for (int i = 0; i <= inputNum; i++) {
                    resultNum += i;
                }
                System.out.println("Ответ:"+resultNum);
                sc.close();
                return;
            } else {
                System.out.println("Не числовой тип данных!");
                sc.next();
            }
        }

    }

}




